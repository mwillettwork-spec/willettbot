{
  "name": "willettbot",
  "version": "1.0.17",
  "description": "Desktop automation for non-technical users — record, edit, and replay macros.",
  "main": "main.js",
  "author": {
    "name": "Myles Willett",
    "email": "mwillettwork@gmail.com"
  },
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "prepare-python": "bash scripts-build/prepare-python.sh",
    "strip-xattrs": "xattr -cr node_modules/electron 2>/dev/null || true",
    "clean-dist": "rm -rf dist-app",
    "dist": "npm run clean-dist && npm run strip-xattrs && npm run prepare-python && electron-builder --mac --x64 --publish always",
    "dist:dmg": "npm run clean-dist && npm run strip-xattrs && npm run prepare-python && electron-builder --mac dmg",
    "pack": "npm run clean-dist && npm run strip-xattrs && npm run prepare-python && electron-builder --dir"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^24.13.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "build": {
    "appId": "com.willett.willettbot",
    "productName": "WillettBot",
    "artifactName": "WillettBot-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist-app",
      "buildResources": "build-assets"
    },
    "afterPack": "./scripts-build/after-pack.js",
    "files": [
      "main.js",
      "hub.html",
      "index.html",
      "toast.html",
      "renderer.js",
      "recorder.py",
      "runner.py",
      "clicker.py",
      "emailer.py",
      "permcheck.py",
      "licensing/public_key.pem",
      "licensing/keygen.js",
      "PRIVACY.md",
      "TERMS.md",
      "NOTICES.md",
      "node_modules/**/*",
      "package.json",
      "!**/__pycache__/**",
      "!**/*.pyc",
      "!licensing/private_key.pem",
      "!activation.json",
      "!favorites.json",
      "!schedules.json",
      "!scripts/**",
      "!dist-app/**"
    ],
    "asarUnpack": [
      "*.py"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts-seed",
        "filter": [
          "**/*.json"
        ]
      },
      {
        "from": "bundled-python/python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build-assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build-assets/entitlements.mac.plist",
      "entitlementsInherit": "build-assets/entitlements.mac.plist",
      "notarize": {
        "teamId": "MP2LL5ZQC5"
      }
    },
    "dmg": {
      "title": "${productName} ${version}",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 180,
          "type": "file"
        },
        {
          "x": 400,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "mwillettwork-spec",
        "repo": "willettbot",
        "private": true,
        "releaseType": "release"
      }
    ]
  }
}
